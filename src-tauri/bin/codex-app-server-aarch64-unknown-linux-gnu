#!/usr/bin/env bash
set -euo pipefail

# GUI app launches often have a minimal PATH; include common Codex + Node locations.
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.mise/shims:${PATH:-}"

if [[ "${NARRATIVE_CODEX_APP_SERVER_FORCE_SHIM:-0}" == "1" ]]; then
  while IFS= read -r line; do
    if [[ "$line" == *"shutdown"* ]]; then
      exit 0
    fi
    echo "{\"result\":{\"ok\":true},\"id\":null}"
  done
  exit 0
fi

if command -v codex >/dev/null 2>&1; then
  exec codex app-server "$@"
fi

for candidate in \
  /opt/homebrew/bin/codex \
  /usr/local/bin/codex \
  "$HOME/.local/bin/codex" \
  "$HOME/.cargo/bin/codex" \
  "$HOME/.mise/shims/codex"
do
  if [[ -x "$candidate" ]]; then
    exec "$candidate" app-server "$@"
  fi
done

echo "codex CLI not found; install codex-cli or set NARRATIVE_CODEX_APP_SERVER_BIN." >&2
exit 127
